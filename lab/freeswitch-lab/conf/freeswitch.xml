<?xml version="1.0"?>
<!--
  freeswitch.xml — Root FreeSWITCH configuration
  Lab environment: mounts all config from lab/freeswitch-lab/conf/

  This file is required by FreeSWITCH as the XML root.
  It includes vars.xml (generated by entrypoint from vars.xml.tpl) and
  then pulls in all subsections via glob includes.
-->
<document type="freeswitch/xml">

  <!-- Generated from vars.xml.tpl by docker-entrypoint.sh -->
  <X-PRE-PROCESS cmd="include" data="/etc/freeswitch/vars.xml"/>

  <!-- Module configuration: loading, Sofia, ESL, Lua, logging, etc. -->
  <section name="configuration" description="Various Configuration">
    <X-PRE-PROCESS cmd="include" data="/etc/freeswitch/autoload_configs/*.xml"/>
  </section>

  <!-- Dialplan: default (inbound DID/IVR) + internal (extension dialing) -->
  <section name="dialplan" description="Regex/XML Dialplan">
    <X-PRE-PROCESS cmd="include" data="/etc/freeswitch/dialplan/*.xml"/>
  </section>

  <!-- No chatplan needed in VoIP-only platform -->
  <section name="chatplan" description="Chatplan"/>

  <!-- User directory: Fanvil phones register as extensions 1001-1005 -->
  <section name="directory" description="User Directory">
    <X-PRE-PROCESS cmd="include" data="/etc/freeswitch/directory/**/*.xml"/>
  </section>

</document>
