# lab/.env.lab.example — Lab environment variables template
# Copy to .env.lab and fill in the three REQUIRED values.
# This file is safe to commit. .env.lab is gitignored.
#
# Usage:
#   cp .env.lab.example .env.lab
#   # edit .env.lab with real values
#   bash scripts/setup-lab.sh

# ─────────────────────────────────────────
# REQUIRED — change these before starting
# ─────────────────────────────────────────

# Internal service token — shared between FreeSWITCH Lua scripts and FastAPI.
# Any random string works in the lab (min 16 chars).
# Generate: openssl rand -hex 16
INTERNAL_TOKEN=change-me-lab-token

# FreeSWITCH Event Socket password.
# ClueCon is the well-known default — fine for local lab, change for staging.
FS_ESL_PASSWORD=ClueCon

# JWT signing secret — FastAPI uses this to validate internal service JWTs.
# Generate: openssl rand -hex 32
INTERNAL_JWT_SECRET=change-me-at-least-32-chars-long-please

# ─────────────────────────────────────────
# DATABASE — defaults match docker-compose.lab.yml
# ─────────────────────────────────────────
POSTGRES_DB=galaxy_2
POSTGRES_USER=dev_ifx
POSTGRES_PASSWORD=labpass

# ─────────────────────────────────────────
# SIGNALWIRE — FreeSWITCH package build token
# Required ONLY if you need to rebuild the FreeSWITCH Docker image.
# Get from: https://signalwire.com
# Store in: ../freeswitch/.signalwire_token  (never in this file)
# ─────────────────────────────────────────

# ─────────────────────────────────────────
# OPTIONAL OVERRIDES
# ─────────────────────────────────────────

# Override if your host machine is not on 192.168.x.x
# Used only for the setup script's diagnostic output.
# HOST_IP=192.168.1.100

# Grafana admin password (default: admin)
# GF_SECURITY_ADMIN_PASSWORD=admin
