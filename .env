##
## .env.example — Environment variable template for local development
##
## Copy to .env and fill in values:
##   cp .env.example .env
##
## NEVER commit .env to version control.
## In production: all secrets are injected by ECS from AWS Secrets Manager.
## In FreeSWITCH EC2: inject via user-data startup script (see CLAUDE.md).

# ── PostgreSQL (local dev only — production uses RDS) ────────────────────────
POSTGRES_USER=dev_ifx
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=galaxy_2

# ── FastAPI / Billing Worker ──────────────────────────────────────────────────
# For local dev, these point to the Docker Compose service names.
# For production, DATABASE_URL points to RDS, REDIS_URL to ElastiCache.
DATABASE_URL=postgresql+asyncpg://dev_ifx:devpassword@postgres:5432/galaxy_2
REDIS_URL=redis://redis:6379/0

# JWT shared secret between Lua (FreeSWITCH) and FastAPI.
# MUST be a strong random string in production.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_JWT_SECRET=changeme-generate-a-strong-secret-for-production

# ── FreeSWITCH ────────────────────────────────────────────────────────────────
# ESL password — shared between FreeSWITCH and billing worker.
# MUST match event_socket.conf.xml (generated by docker-entrypoint.sh).
# Change from ClueCon default in staging/production.
FS_ESL_PASSWORD=ClueCon

# Internal token for Lua → FastAPI HTTP calls (R-SIP-01).
# Must match INTERNAL_JWT_SECRET above.
VOIP_INTERNAL_TOKEN=changeme-match-internal-jwt-secret

# API base URL — FreeSWITCH Lua scripts POST to this.
# In Docker Compose: http://api:8000 (service name resolution)
# In production EC2: http://<ALB-DNS-NAME>:80 or https://api.internal/
VOIP_API_BASE_URL=http://api:8000

# ── Voxbone SIP credentials (from Secrets Manager in production) ─────────────
# Leave empty in local dev unless testing real SIP registration.
VOXBONE_USERNAME=
VOXBONE_PASSWORD=
VOXBONE_REALM=sip.voxbone.com
VOXBONE_PROXY=sip.voxbone.com

# ── FreeSWITCH IVR / Billing tuning ─────────────────────────────────────────
# These match the legacy sofia.conf values. Only change if adjusting behaviour.
VOIP_HTTP_TIMEOUT_MS=2000
VOIP_TICK_TIMEOUT_MS=1500
VOIP_WARN_REMAINING_SEC=320
VOIP_BEEP_REMAINING_SEC=10
VOIP_AUTH_ATTEMPTS=3
VOIP_PIN_LENGTH=8
VOIP_DTMF_TIMEOUT_MS=5000
VOIP_DEFAULT_GATEWAY=voxbone-outbound

# ── API host port mapping (local dev) ────────────────────────────────────────
# The FastAPI service is accessible at http://localhost:${API_HOST_PORT}
API_HOST_PORT=8080

# ── Production-only variables (not used in docker-compose.yml) ───────────────
# Set these in your CI/CD pipeline or AWS Secrets Manager:
# ECR_REGISTRY=<account-id>.dkr.ecr.<region>.amazonaws.com
# ECR_API_REPO=voip-platform/api
# IMAGE_TAG=latest
# UVICORN_WORKERS=2
# FREESWITCH_PRIVATE_IP=<EC2-private-ip>
